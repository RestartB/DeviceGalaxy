{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:daily"
  ],
  "rangeStrategy": "pin",
  "minimumReleaseAge": "3 days",
  "ignoreDeps": [
    "restartb/devicegalaxy"
  ],
  "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
